# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=dorm_power_guard

# 爬虫配置（西华大学一卡通宿舍用电小程序）
CRAWLER_BASE_URL=https://ecard.xhu.edu.cn
CRAWLER_API_BASE_URL=https://ecard.xhu.edu.cn/api
CRAWLER_DORM_NUMBER=101
CRAWLER_OPENID=your_openid_from_capture
CRAWLER_JSESSIONID=your_jsessionid_from_capture
CRAWLER_ROOM_ID=5699

# 定时任务：每 N 小时检测一次电费并检查告警
SCHEDULER_INTERVAL_HOURS=2
# 同类告警最短间隔（小时），建议与 SCHEDULER_INTERVAL_HOURS 一致
ALERT_COOLDOWN_HOURS=2
# QQ告警暂停至该日期（不含），到达当日自动恢复，格式 YYYY-MM-DD；留空表示不暂停
QQ_ALERT_PAUSE_UNTIL=

# QQ机器人（NoneBot，仅群消息；机器人QQ固定 1270667498）
QQ_BOT_ENABLED=false
QQ_BOT_API_URL=http://127.0.0.1:8080
QQ_BOT_API_TOKEN=请生成至少32位随机字符串
QQ_BOT_GROUP_ID=6011223303

# 默认告警阈值
DEFAULT_ALERT_THRESHOLD=20.0

# 本地开发可开启调试（允许弱口令、返回详细异常）
APP_DEBUG=true

# 管理登录（唯一用户 root，无注册/改密）
# 生产环境：APP_DEBUG=false，且密码≥12位、JWT密钥≥32位
ADMIN_USERNAME=root
ADMIN_PASSWORD=dev-only-change-me
ADMIN_JWT_SECRET=dev-only-jwt-secret-must-be-at-least-32-chars
ADMIN_TOKEN_EXPIRE_HOURS=168
