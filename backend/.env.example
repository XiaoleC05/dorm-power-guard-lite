# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=dorm_power_guard

# 爬虫配置（西华大学一卡通宿舍用电小程序）
# 系统地址：https://ecard.xhu.edu.cn
CRAWLER_BASE_URL=https://ecard.xhu.edu.cn
CRAWLER_API_BASE_URL=https://ecard.xhu.edu.cn/api
# Token通过抓包工具获取（推荐方式）
CRAWLER_TOKEN=your_token_from_capture_tool
# 如果小程序支持账号密码登录，可以使用以下配置（通常不支持）
CRAWLER_USERNAME=your_username
CRAWLER_PASSWORD=your_password
CRAWLER_DORM_NUMBER=101
# Token刷新接口（如果Token会过期）
CRAWLER_TOKEN_REFRESH_URL=https://ecard.xhu.edu.cn/api/auth/refresh

# 定时任务：每 N 小时检测一次电费并检查告警
SCHEDULER_INTERVAL_HOURS=2
# 同类告警最短间隔（小时），建议与 SCHEDULER_INTERVAL_HOURS 一致
ALERT_COOLDOWN_HOURS=2
# QQ告警暂停至该日期（不含），到达当日自动恢复，格式 YYYY-MM-DD；留空表示不暂停
QQ_ALERT_PAUSE_UNTIL=

# 邮件配置
# 启用邮件告警功能
EMAIL_ENABLED=false

# SMTP服务器配置（QQ邮箱示例）
# QQ邮箱SMTP服务器：smtp.qq.com
# QQ邮箱SMTP端口：465（SSL）或587（STARTTLS）
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=465

# SMTP登录账号（QQ邮箱地址）
EMAIL_SMTP_USER=your_qq_email@qq.com

# SMTP登录密码（QQ邮箱授权码，不是QQ密码！）
# 获取授权码方法：
# 1. 登录QQ邮箱网页版：https://mail.qq.com
# 2. 点击"设置" -> "账户"
# 3. 找到"POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV服务"
# 4. 开启"POP3/SMTP服务"或"IMAP/SMTP服务"
# 5. 点击"生成授权码"，按提示发送短信后获取授权码
# 6. 将授权码填入此处（注意：授权码不是QQ密码）
EMAIL_SMTP_PASSWORD=your_qq_email_auth_code

# 发件人邮箱地址（通常与EMAIL_SMTP_USER相同）
EMAIL_FROM=your_qq_email@qq.com

# 默认接收邮箱（多个邮箱用逗号分隔，可选）
# 注意：如果告警规则中配置了email_address，将优先使用规则中的邮箱
EMAIL_TO=recipient1@example.com,recipient2@example.com

# QQ机器人（NoneBot，仅群消息；机器人QQ固定 1270667498）
QQ_BOT_ENABLED=false
QQ_BOT_API_URL=http://127.0.0.1:8080
QQ_BOT_GROUP_ID=6011223303
QQ_BOT_ACCESS_TOKEN=

# 默认告警阈值
DEFAULT_ALERT_THRESHOLD=20.0

# 管理登录（唯一用户 root，无注册/改密）
ADMIN_USERNAME=root
ADMIN_PASSWORD=783688
ADMIN_JWT_SECRET=please-change-this-secret
ADMIN_TOKEN_EXPIRE_HOURS=168
