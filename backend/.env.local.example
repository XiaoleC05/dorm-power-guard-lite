# 本地开发专用（docker compose -f docker-compose.dev.yml up -d）
# 复制为 backend/.env：  copy backend\.env.local.example backend\.env

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=dev_local
DB_NAME=dorm_guard

APP_DEBUG=true

ADMIN_USERNAME=root
ADMIN_PASSWORD=dev-only-change-me
ADMIN_JWT_SECRET=dev-only-jwt-secret-must-be-at-least-32-chars
ADMIN_TOKEN_EXPIRE_HOURS=168

QQ_BOT_ENABLED=false

# Oxelia51 本地网关联调（平台 :8080 loopback 转发时设为 true）
OXELIA_GATEWAY_MODE=true

# 爬虫凭证本地可留空；启动后 /health 可用，定时抓取会失败属正常
CRAWLER_DORM_NUMBER=101
SCHEDULER_INTERVAL_HOURS=24
ALERT_COOLDOWN_HOURS=24
